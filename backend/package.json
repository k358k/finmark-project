{
  "name": "backend",
  "version": "2.0.0",
  "description": "FinMark microservices backend",
  "scripts": {
    "seed": "node seed/seed.js",
    "start:auth": "PORT=3001 node auth-service/server.js",
    "start:auth:standby": "PORT=3011 node auth-service/server.js",
    "start:orders": "PORT=3002 node orders-service/server.js",
    "start:orders:standby": "PORT=3012 node orders-service/server.js",
    "start:products": "PORT=3003 node products-service/server.js",
    "start:products:standby": "PORT=3013 node products-service/server.js",
    "start:reports": "PORT=3004 node reports-service/server.js",
    "start:reports:standby": "PORT=3014 node reports-service/server.js",
    "start:all": "concurrently \"npm run start:auth\" \"npm run start:auth:standby\" \"npm run start:orders\" \"npm run start:orders:standby\" \"npm run start:products\" \"npm run start:products:standby\" \"npm run start:reports\" \"npm run start:reports:standby\"",
    "test:auth": "npm test --prefix auth-service",
    "test:orders": "npm test --prefix orders-service",
    "test:products": "npm test --prefix products-service -- --passWithNoTests",
    "test:reports": "npm test --prefix reports-service",
    "test:all": "npm run test:auth && npm run test:orders && npm run test:products && npm run test:reports"
  },
  "dependencies": {
    "argon2": "^0.41.1",
    "dotenv": "^16.4.7",
    "mongoose": "^8.9.5"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
